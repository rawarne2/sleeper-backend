# Sleeper Backend — REST Client
# Define ALL @variables before any request that uses them.

@BASE_URL = http://localhost:5001
# @BASE_URL = https://your-backend.example.com

# Default league = 2026 season (change to match the league you are testing. examples at the bottom)
@LEAGUE_ID = 1333945997071515648

@SEASON = 2026
@WEEK = 1
# Research + weekly stats query param (string: dynasty | redraft)
@LEAGUE_TYPE = dynasty

# KTC query bundles (league_format is 1qb|superflex; not the same as LEAGUE_TYPE above)
@KTC_QS_SUPERFLEX_DYN_TEP = tep_level=tep&is_redraft=false&league_format=superflex
@KTC_QS_1QB_DYN_TEP = tep_level=tep&is_redraft=false&league_format=1qb
@KTC_QS_SUPERFLEX_REDRAFT = tep_level=&is_redraft=true&league_format=superflex

# Same value as server CRON_SECRET (never commit real secrets)
@CRON_SECRET = your-cron-secret

### ============================================================================
### VARIABLES / ENV (see bottom for reference + Redis / secrets)
### ============================================================================

### Verify maintenance routes are live (GET should be 200 JSON — if 404, wrong BASE_URL or old deploy)
GET {{BASE_URL}}/api/maintenance/health

### Nightly full sync — GET (matches Vercel Cron) or POST; requires CRON_SECRET on server
GET {{BASE_URL}}/api/maintenance/nightly-sync
Authorization: Bearer {{CRON_SECRET}}

### Daily refresh — optional X-Daily-Refresh-Secret when DAILY_REFRESH_SECRET is set on server
POST {{BASE_URL}}/api/maintenance/daily-refresh
Content-Type: application/json
Accept: application/json

{}

# X-Daily-Refresh-Secret: {{DAILY_REFRESH_SECRET}}

### ============================================================================
### Health
### ============================================================================

GET {{BASE_URL}}/api/ktc/health

### ============================================================================
### Sleeper — NFL players (RARE: takes 60s+, run manually ~1x/year)
### ============================================================================

POST {{BASE_URL}}/api/sleeper/refresh

### ============================================================================
### Dashboard bundle — single GET (Redis/DB only; no Sleeper/KTC scrape in request)
### ============================================================================

GET {{BASE_URL}}/api/dashboard/league/{{LEAGUE_ID}}?season={{SEASON}}&{{KTC_QS_SUPERFLEX_DYN_TEP}}

### ============================================================================
### Sleeper — one league (GET / PUT / POST refresh)
### ============================================================================

GET {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}
PUT {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}
POST {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}

GET {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/rosters
GET {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/users

### ============================================================================
### Sleeper — research (ownership %); week + league_type optional on GET
### ============================================================================

GET {{BASE_URL}}/api/sleeper/players/research/{{SEASON}}?week={{WEEK}}&league_type={{LEAGUE_TYPE}}
POST {{BASE_URL}}/api/sleeper/players/research/{{SEASON}}?week={{WEEK}}&league_type={{LEAGUE_TYPE}}
PUT {{BASE_URL}}/api/sleeper/players/research/{{SEASON}}?week={{WEEK}}&league_type={{LEAGUE_TYPE}}

### ============================================================================
### Sleeper — weekly stats (league in path may differ from @SEASON)
### ============================================================================

POST {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/stats/seed
Content-Type: application/json

{
  "league_name": "Salt Factory",
  "season": "2026",
  "league_type": "{{LEAGUE_TYPE}}"
}

PUT {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/stats/week/{{WEEK}}?season={{SEASON}}&league_type={{LEAGUE_TYPE}}
POST {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/stats/week/{{WEEK}}?season={{SEASON}}&league_type={{LEAGUE_TYPE}}
GET {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/stats/week/{{WEEK}}?season={{SEASON}}&league_type={{LEAGUE_TYPE}}
GET {{BASE_URL}}/api/sleeper/league/{{LEAGUE_ID}}/stats/week/{{WEEK}}?season={{SEASON}}&league_type={{LEAGUE_TYPE}}&average=true

### ============================================================================
### KTC — refresh (POST and PUT both supported on /api/ktc/refresh)
### Default: HTTP 202 + job_id (fast ack). Blocking scrape+DB: add &sync=1
### ============================================================================

POST {{BASE_URL}}/api/ktc/refresh/all

POST {{BASE_URL}}/api/ktc/refresh?{{KTC_QS_SUPERFLEX_DYN_TEP}}
# GET {{BASE_URL}}/api/ktc/refresh/status/<job_id from 202 body>
# POST {{BASE_URL}}/api/ktc/refresh?{{KTC_QS_SUPERFLEX_DYN_TEP}}&sync=1
POST {{BASE_URL}}/api/ktc/refresh?{{KTC_QS_1QB_DYN_TEP}}
POST {{BASE_URL}}/api/ktc/refresh?{{KTC_QS_SUPERFLEX_REDRAFT}}

### ============================================================================
### KTC — read rankings (dashboard uses superflex + dynasty + tep)
### ============================================================================

GET {{BASE_URL}}/api/ktc/rankings?{{KTC_QS_SUPERFLEX_DYN_TEP}}
# GET {{BASE_URL}}/api/ktc/rankings?{{KTC_QS_1QB_DYN_TEP}}
# GET {{BASE_URL}}/api/ktc/rankings?{{KTC_QS_SUPERFLEX_REDRAFT}}
# GET {{BASE_URL}}/api/ktc/rankings?tep_level=&is_redraft=false&league_format=1qb

### ============================================================================
### KTC — cleanup (destructive; narrow QS to one configuration)
### ============================================================================

POST {{BASE_URL}}/api/ktc/cleanup?{{KTC_QS_SUPERFLEX_DYN_TEP}}

### ============================================================================
### REFERENCE DATA (not executed)
### ============================================================================

# League IDs:
# 2024 league_id: 1050831680350568448
# 2025 league_id: 1210364682523656192
# 2026 league_id: 1333945997071515648

# User ID: 736083244801474560

# Parameter options:
# KTC league_format: "1qb" | "superflex"
# KTC tep_level: "" | "tep" | "tepp" | "teppp"
# KTC is_redraft: "true" | "false"
# Sleeper API league_type query: "dynasty" | "redraft" (maps to 2 | 1 in Sleeper’s API)

# First-time setup order (manual):
# 1) POST /api/sleeper/refresh
# 2) POST /api/ktc/refresh/all   (or targeted /api/ktc/refresh?...)
# 3) GET league / research as needed
# Scheduled: Vercel Cron → GET /api/maintenance/nightly-sync with CRON_SECRET (see .env.example).
