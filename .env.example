# =============================================================================
# Sleeper backend — environment variables
# Copy to `.env` and fill in values. Never commit real `.env` files.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Flask / SQLAlchemy)
# -----------------------------------------------------------------------------
# The app reads TEST_DATABASE_URI first, then DATABASE_URL, then a local default.
# Uncomment ONE primary line for your setup.

# Option 1: Vercel / Supabase / managed Postgres (pooler URL is fine)
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Option 2: Local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5433/sleeper_db?sslmode=disable

# Option 3: Local SQLite (simplest)
# TEST_DATABASE_URI=sqlite:///sleeper_local.db

# Vercel may set POSTGRES_URL, POSTGRES_PRISMA_URL, etc. — vercel_app.py checks those first.

# -----------------------------------------------------------------------------
# Redis (optional) — shared cache for large GET /api/ktc/rankings JSON
# -----------------------------------------------------------------------------
# If unset, rankings still use an in-process cache only (fine for single-worker dev).
# Use a URL from Upstash, Redis Cloud, ElastiCache, etc.
#
# Docker Compose (app runs in a container): the hostname must be the Redis service name, e.g.
#   REDIS_URL=redis://redis:6379/0
# Do NOT use redis://localhost:6379 from inside the sleeper-backend container — localhost is the container itself.
# Redis runs on the host (no Compose redis service): use host.docker.internal on Mac/Windows, e.g.
#   REDIS_URL=redis://host.docker.internal:6379/0
#
# REDIS_URL=

# Optional TTL (seconds) for the Redis copy of rankings JSON. Default: 86400 (24h).
# KTC_RANKINGS_REDIS_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Scheduled ingest — GET/POST /api/maintenance/nightly-sync (Vercel Cron uses GET)
# -----------------------------------------------------------------------------
# CRON_SECRET — required on the server for /nightly-sync (never expose in VITE_* or the browser).
#   • Vercel: add CRON_SECRET in Project → Environment Variables; cron invocations receive
#       Authorization: Bearer <CRON_SECRET>
#   • Manual: curl -H "Authorization: Bearer $CRON_SECRET" https://your-api/api/maintenance/nightly-sync
#   • vercel.json schedule 0 9 * * * = 09:00 UTC ≈ 4:00 AM US/Eastern in standard time;
#     during daylight saving, the same cron runs at 5:00 AM Eastern. For exact America/New_York
#     4:00 AM year-round, use a host whose cron supports a timezone.
# CRON_SECRET=

# When true, nightly/daily refresh (if league_ids not passed in the JSON body) refreshes every
# league_id present in table sleeper_leagues instead of DAILY_REFRESH_LEAGUE_IDS / built-in defaults.
# NIGHTLY_SYNC_ALL_DB_LEAGUES=false

# -----------------------------------------------------------------------------
# Daily maintenance — POST /api/maintenance/daily-refresh (operators only; not for dashboard clients)
# -----------------------------------------------------------------------------
# DAILY_REFRESH_SECRET — optional SERVER-SIDE shared secret.
#   • If EMPTY or unset: anyone who can reach the API may POST /daily-refresh (OK for local dev only).
#   • If SET: requests must send HTTP header:
#       X-Daily-Refresh-Secret: <same string as DAILY_REFRESH_SECRET>
#     The header name is fixed in code; the value is whatever you choose.
#   • Generate a value e.g.:  openssl rand -hex 32
#   • This is NOT the same as an API key from Sleeper/Supabase — it’s your own password for this route.
# DAILY_REFRESH_SECRET=

# Optional overrides for the daily job (comma-separated). Defaults are built-in if unset.
# DAILY_REFRESH_LEAGUE_IDS=1333945997071515648,1210364682523656192,1050831680350568448
# DAILY_REFRESH_SEASONS=2024,2025,2026
# DAILY_REFRESH_RESEARCH_WEEK=1

# -----------------------------------------------------------------------------
# KTC scraping (KeepTradeCut)
# -----------------------------------------------------------------------------
# KTC_FETCH_TIMEOUT_SECONDS=120
# KTC_FETCH_RETRIES=2

# -----------------------------------------------------------------------------
# App / debugging
# -----------------------------------------------------------------------------
# IS_DEV=True
# LOG_UNMATCHED_KTC_MERGE=true

# -----------------------------------------------------------------------------
# Gunicorn (production process model)
# -----------------------------------------------------------------------------
# GUNICORN_WORKERS=5
# GUNICORN_TIMEOUT=9999
# GUNICORN_GRACEFUL_TIMEOUT=9999

# -----------------------------------------------------------------------------
# AWS S3 (optional — file uploads from some KTC refresh paths)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# VERCEL=1                    # set automatically on Vercel (see wsgi.py)
# REMOTE_DEBUG=1              # Docker: debugpy attach on port 5678

# -----------------------------------------------------------------------------
# Frontend / clients (not read by this Flask app — document only)
# -----------------------------------------------------------------------------
# VITE_API_URL=https://your-backend.example.com/api   # sleeper-dashboard production
