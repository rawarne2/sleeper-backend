# Database Configuration
# Uncomment ONE of the following database options:

# Option 1: Vercel/Supabase PostgreSQL (recommended for matching production)
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Option 2: Local PostgreSQL (via Docker or native install)
# DATABASE_URL=postgresql://postgres:password@localhost:5433/sleeper_db?sslmode=disable

# Option 3: Local SQLite (simplest, no setup needed - used by default if nothing is set)
# TEST_DATABASE_URI=sqlite:///sleeper_local.db

# Application Settings
# IS_DEV=True
# BASE_URL=http://localhost:5001

# Docker: set REMOTE_DEBUG=1 to run with debugpy so VS Code can attach (port 5678)
# REMOTE_DEBUG=1

# AWS Credentials for S3 Upload (optional)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=your-bucket-name
