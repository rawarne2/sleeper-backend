# Copy to `.env`. Compose reads the host file for substitution into the app container.

# Postgres (local/compose: host `postgres` when using docker-compose; Vercel: provider URL)
DATABASE_URL=postgresql://postgres:password@postgres:5432/sleeper_db?sslmode=disable

# Optional: overrides DATABASE_URL if set (e.g. sqlite for quick tests). Pytest defaults in-memory if unset.
# TEST_DATABASE_URI=sqlite:///./local.db

# Redis — empty ok for local tests; compose: redis://redis:6379/0 (not localhost from inside the container); Vercel prod: set for shared rankings cache
REDIS_URL=redis://redis:6379/0

# Bearer for /api/maintenance/nightly-sync and /prewarm. Vercel production + cron: required. Generate: openssl rand -hex 32
CRON_SECRET=

DAILY_REFRESH_RESEARCH_WEEK=1

IS_DEV=True
SECRET_KEY=

# --- Optional (defaults usually fine; see code / docker-compose.yml) ---
# ENABLE_DEBUG_TOOLBAR=1
# DASHBOARD_LEAGUE_REDIS_TTL_SECONDS=86400
# KTC_RANKINGS_REDIS_TTL_SECONDS=86400
# KTC_FETCH_TIMEOUT_SECONDS=120
# KTC_FETCH_RETRIES=2
# LOG_UNMATCHED_KTC_MERGE=true
# KTC_EXPORT_JSON_AND_S3=true
# KTC_WRITE_UNMATCHED_MERGE_REPORT=true
# GUNICORN_WORKERS=  GUNICORN_TIMEOUT=  GUNICORN_GRACEFUL_TIMEOUT=
# REMOTE_DEBUG=1
# AWS_ACCESS_KEY_ID=  AWS_SECRET_ACCESS_KEY=  AWS_DEFAULT_REGION=us-east-1  S3_BUCKET=

# --- AI Trade Analyzer ---
TRADE_ANALYZER_ENABLED=true
TRADE_ANALYZER_DEFAULT_PROVIDER=ollama
TRADE_ANALYZER_RATE_LIMIT_PER_HOUR=20
TRADE_ANALYZER_RATE_LIMIT_KEY=ip
TRADE_ANALYZER_PICK_HORIZON_YEARS=3
# TRADE_ANALYZER_DEBUG_LOG=1  # log parsed request + full system/user prompts to server stdout
#
# Production routing lock (Gemini only). Local: omit or false. Vercel production: omit (auto via VERCEL_ENV).
# TRADE_ANALYZER_PRODUCTION_LOCK=false
#
# TRADE_ANALYZER_ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (AI Studio / Generative Language API). Optional model and timeout overrides:
# TRADE_ANALYZER_GEMINI_MODEL=gemini-2.5-flash
# TRADE_ANALYZER_GEMINI_TIMEOUT_SECONDS=60
# TRADE_ANALYZER_GEMINI_THINKING_BUDGET=0      # 0 disables 2.5-flash "thinking" — biggest single perf win; raise (e.g. 256) only when you want deeper reasoning at +10-30s latency
# TRADE_ANALYZER_GEMINI_MAX_OUTPUT_TOKENS=2048
# GEMINI_API_KEY=

# Provider health-check cache (in-process; no Redis). Cached successes are reused for 60s, failures for 5s so a recovered provider is picked up fast.
# TRADE_ANALYZER_HEALTH_CHECK_TTL_SECONDS=60
# TRADE_ANALYZER_HEALTH_CHECK_FAILURE_TTL_SECONDS=5

# Ollama — Docker: Compose sets host.docker.internal; if .env uses localhost/127.0.0.1, the app rewrites to host.docker.internal in-container. Native ./startup.sh: default http://localhost:11434 is fine.
# OLLAMA_USE_LOCALHOST_IN_CONTAINER=1 disables that rewrite.
# OLLAMA_HOST=
# TRADE_ANALYZER_OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M
# TRADE_ANALYZER_OLLAMA_MODELS=qwen2.5:14b-instruct-q4_K_M,gemma3:27b  # comma list for the UI; when unset, only TRADE_ANALYZER_OLLAMA_MODEL is offered

# ANTHROPIC_API_KEY=
