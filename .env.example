# Copy to .env (gitignored). Docker Compose reads it for the app container.

# --- Required ---
# DATABASE_URL     Postgres URI. Docker app: host postgres, port 5432. Host machine → DB: localhost:5433. Prod: Vercel / provider env.
# CRON_SECRET      openssl rand -hex 32. Nightly sync: Authorization: Bearer <value>. Prod: Vercel API project.
# DAILY_REFRESH_SECRET  Same style; different from CRON_SECRET. POST .../daily-refresh manual operator use.
# REDIS_URL        Docker: redis://redis:6379/0. Prod: hosted Redis URL.
# SECRET_KEY       openssl rand -hex 32 (e.g. debug toolbar / sessions).
# IS_DEV           True locally; False or unset in prod.

# --- Defaults you can keep ---
# DAILY_REFRESH_RESEARCH_WEEK  Sleeper research week for daily/nightly pipeline (default 1).
DATABASE_URL=postgresql://postgres:password@postgres:5432/sleeper_db?sslmode=disable
CRON_SECRET=
DAILY_REFRESH_SECRET=
DAILY_REFRESH_RESEARCH_WEEK=1
REDIS_URL=redis://redis:6379/0
SECRET_KEY=
IS_DEV=True

# --- Less common ---
# TEST_DATABASE_URI=sqlite:///sleeper_local.db
# KTC_FETCH_TIMEOUT_SECONDS=120
# KTC_FETCH_RETRIES=2
# LOG_UNMATCHED_KTC_MERGE=true
# ENABLE_DEBUG_TOOLBAR=1
# GUNICORN_WORKERS=5
# GUNICORN_TIMEOUT=9999
# GUNICORN_GRACEFUL_TIMEOUT=9999
# AWS_ACCESS_KEY_ID=  AWS_SECRET_ACCESS_KEY=  AWS_DEFAULT_REGION=us-east-1  S3_BUCKET=
# KTC_EXPORT_JSON_AND_S3=true   When true, KTC refresh writes JSON snapshots and uploads to S3 if S3_BUCKET is set. Default: off.
# VERCEL=1  REMOTE_DEBUG=1
