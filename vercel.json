{
  "version": 2,
  "crons": [
    {
      "path": "/api/maintenance/nightly-sync",
      "schedule": "30 15 * * *"
    }
  ],
  "builds": [
    {
      "src": "vercel_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel_app.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "buildCommand": "echo 'Build completed - no Docker required'",
  "installCommand": "pip install -r requirements.txt"
} 